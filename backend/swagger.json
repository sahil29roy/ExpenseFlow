{
  "openapi": "3.0.0",
  "info": {
    "title": "Expense Sharing System API",
    "description": "Production-ready REST API for splitwise-like Expense Sharing System featuring connection pooling, transactions, custom split types, settlements, dashboard, CSV importing, and pagination.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:5000",
      "description": "Local Development Server"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "User": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "name": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "Group": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "name": { "type": "string" },
          "description": { "type": "string", "nullable": true },
          "created_by": { "type": "string", "format": "uuid" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "Expense": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "group_id": { "type": "string", "format": "uuid", "nullable": true },
          "description": { "type": "string" },
          "total_amount": { "type": "string" },
          "paid_by": { "type": "string", "format": "uuid" },
          "split_type": { "type": "string", "enum": ["EQUAL", "EXACT", "PERCENTAGE", "UNEQUAL"] },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "ExpenseSplit": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "expense_id": { "type": "string", "format": "uuid" },
          "user_id": { "type": "string", "format": "uuid" },
          "amount": { "type": "string" },
          "percentage": { "type": "string", "nullable": true }
        }
      },
      "Settlement": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "group_id": { "type": "string", "format": "uuid", "nullable": true },
          "payer_id": { "type": "string", "format": "uuid" },
          "payee_id": { "type": "string", "format": "uuid" },
          "amount": { "type": "string" },
          "settled_at": { "type": "string", "format": "date-time" }
        }
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/api/auth/register": {
      "post": {
        "summary": "Register a new user",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "email", "password"],
                "properties": {
                  "name": { "type": "string", "example": "Alice Smith" },
                  "email": { "type": "string", "format": "email", "example": "alice@example.com" },
                  "password": { "type": "string", "format": "password", "example": "password123" }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User registered successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string", "example": "success" },
                    "data": {
                      "type": "object",
                      "properties": {
                        "user": { "$ref": "#/components/schemas/User" },
                        "token": { "type": "string" }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "summary": "Authenticate user and return JWT",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": { "type": "string", "format": "email", "example": "alice@example.com" },
                  "password": { "type": "string", "format": "password", "example": "password123" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Authentication successful",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string", "example": "success" },
                    "data": {
                      "type": "object",
                      "properties": {
                        "user": { "$ref": "#/components/schemas/User" },
                        "token": { "type": "string" }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/groups": {
      "post": {
        "summary": "Create a new group (Creator is automatically added as member)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name"],
                "properties": {
                  "name": { "type": "string", "example": "Apartment 4B" },
                  "description": { "type": "string", "example": "Splitting household rent and bills" }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Group created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string", "example": "success" },
                    "data": {
                      "type": "object",
                      "properties": {
                        "group": { "$ref": "#/components/schemas/Group" }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "get": {
        "summary": "List groups the authenticated user belongs to (Supports Pagination)",
        "parameters": [
          { "name": "limit", "in": "query", "schema": { "type": "integer" }, "description": "Number of groups per page" },
          { "name": "page", "in": "query", "schema": { "type": "integer" }, "description": "Page number starting at 1" }
        ],
        "responses": {
          "200": {
            "description": "List of user's groups",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string", "example": "success" },
                    "data": {
                      "type": "object",
                      "properties": {
                        "groups": { "type": "array", "items": { "$ref": "#/components/schemas/Group" } },
                        "pagination": { "type": "object", "nullable": true }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/groups/{id}": {
      "get": {
        "summary": "Retrieve group details and member list",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": {
            "description": "Group details",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string", "example": "success" },
                    "data": {
                      "type": "object",
                      "properties": {
                        "group": { "$ref": "#/components/schemas/Group" },
                        "members": { "type": "array", "items": { "$ref": "#/components/schemas/User" } }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "put": {
        "summary": "Update group details (Members only)",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name"],
                "properties": {
                  "name": { "type": "string", "example": "Co-living Apartment 4B" },
                  "description": { "type": "string", "example": "Rent and grocery splitting" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Group updated",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string", "example": "success" },
                    "data": {
                      "type": "object",
                      "properties": {
                        "group": { "$ref": "#/components/schemas/Group" }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "delete": {
        "summary": "Delete a group (Creator only)",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": {
            "description": "Group deleted",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string", "example": "success" },
                    "message": { "type": "string", "example": "Group deleted successfully" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/groups/{id}/members": {
      "get": {
        "summary": "Get member list for group",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": {
            "description": "Members list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string", "example": "success" },
                    "results": { "type": "integer" },
                    "data": {
                      "type": "object",
                      "properties": {
                        "members": { "type": "array", "items": { "$ref": "#/components/schemas/User" } }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Add a new member to a group",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["userId"],
                "properties": {
                  "userId": { "type": "string", "format": "uuid", "example": "01ba4268-050f-4eb6-b591-7c01a95188d4" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Member added successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string", "example": "success" },
                    "data": { "type": "object" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/groups/{id}/members/{userId}": {
      "delete": {
        "summary": "Remove a member from a group",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } },
          { "name": "userId", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": {
            "description": "Member removed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string", "example": "success" },
                    "message": { "type": "string", "example": "Member removed from group successfully" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/expenses": {
      "post": {
        "summary": "Create a new expense split record atomically using transactions",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["description", "totalAmount", "splitType", "participants"],
                "properties": {
                  "description": { "type": "string", "example": "Living room rug" },
                  "totalAmount": { "type": "number", "example": 300.00 },
                  "groupId": { "type": "string", "format": "uuid", "nullable": true, "example": "e97d21d3-14de-45e8-9f34-1c9af526adc1" },
                  "splitType": { "type": "string", "enum": ["EQUAL", "EXACT", "PERCENTAGE", "UNEQUAL"], "example": "EQUAL" },
                  "paidBy": { "type": "string", "format": "uuid", "description": "Optional: defaults to caller ID" },
                  "participants": {
                    "type": "array",
                    "description": "User splits (must equal total amount/percentage)",
                    "items": {
                      "type": "object",
                      "required": ["userId"],
                      "properties": {
                        "userId": { "type": "string", "format": "uuid", "example": "af27186d-8e35-4f04-be5d-715722bab49b" },
                        "amount": { "type": "number", "description": "For EXACT/UNEQUAL splits" },
                        "percentage": { "type": "number", "description": "For PERCENTAGE splits" }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Expense created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string", "example": "success" },
                    "data": { "type": "object" }
                  }
                }
              }
            }
          }
        }
      },
      "get": {
        "summary": "List paginated expenses involving the authenticated user",
        "parameters": [
          { "name": "limit", "in": "query", "schema": { "type": "integer" } },
          { "name": "page", "in": "query", "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "Paginated user expenses ledger",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string", "example": "success" },
                    "data": {
                      "type": "object",
                      "properties": {
                        "expenses": { "type": "array", "items": { "$ref": "#/components/schemas/Expense" } },
                        "pagination": { "type": "object" }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/expenses/balances": {
      "get": {
        "summary": "Get user net balances, debts owed to others, and credits owed by others",
        "responses": {
          "200": {
            "description": "User balance sheet detail",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string", "example": "success" },
                    "data": { "type": "object" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/expenses/settlements": {
      "get": {
        "summary": "Get simplified global debt settlements (Greedy min cash flow optimization)",
        "responses": {
          "200": {
            "description": "List of settlement recommendations",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string", "example": "success" },
                    "data": { "type": "object" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/expenses/import": {
      "post": {
        "summary": "Import expense sheets from a CSV file atomically",
        "description": "Upload a CSV with columns: date, description, paid_by, amount, split_type, split_with, split_details, notes",
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": { "type": "string", "format": "binary" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "CSV Import processed",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string", "example": "success" },
                    "message": { "type": "string" },
                    "data": { "type": "object" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/settlements": {
      "post": {
        "summary": "Record a payment settlement between users",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["payeeId", "amount"],
                "properties": {
                  "payeeId": { "type": "string", "format": "uuid", "example": "af27186d-8e35-4f04-be5d-715722bab49b" },
                  "amount": { "type": "number", "example": 50.00 },
                  "groupId": { "type": "string", "format": "uuid", "nullable": true },
                  "payerId": { "type": "string", "format": "uuid", "description": "Optional: defaults to caller ID" }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Settlement payment recorded",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string", "example": "success" },
                    "data": { "$ref": "#/components/schemas/Settlement" }
                  }
                }
              }
            }
          }
        }
      },
      "get": {
        "summary": "Get authenticated user's settlement payment history",
        "responses": {
          "200": {
            "description": "Settlements history",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string", "example": "success" },
                    "data": { "type": "array", "items": { "$ref": "#/components/schemas/Settlement" } }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/dashboard": {
      "get": {
        "summary": "Retrieve user dashboard metrics and paginated ledger history feed",
        "parameters": [
          { "name": "limit", "in": "query", "schema": { "type": "integer" } },
          { "name": "page", "in": "query", "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "Dashboard metadata and metrics",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string", "example": "success" },
                    "data": { "type": "object" }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
